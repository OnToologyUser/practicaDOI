@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix ex: <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Shape 1 - Nomination must have a person

ex:NominationPersonShape
    a sh:NodeShape ;
    sh:targetClass ex:Nomination ;
    sh:property [
        sh:path ex:person ;
        sh:minCount 1 ;
        sh:message "Every nomination must reference a person." ;
    ] .

# Shape 2 - Nomination must have a film

ex:NominationFilmShape
    a sh:NodeShape ;
    sh:targetClass ex:Nomination ;
    sh:property [
        sh:path ex:film ;
        sh:minCount 1 ;
        sh:message "Every nomination must reference a film" ;
    ] .

# Shape 3 - winner must be boolean

ex:WinnerDatatypeShape
    a sh:NodeShape ;
    sh:targetClass ex:Nomination ;
    sh:property [
        sh:path ex:winner ;
        sh:datatype xsd:boolean ;
        sh:message "Winner value must be true or false" ;
    ] .

# Shape 4 - year format has to be YYYY or YYYY/YY (for seasons redacted like 1927/28)

ex:YearPatternShape
    a sh:NodeShape ;
    sh:targetClass ex:Nomination ;
    sh:property [
        sh:path ex:year ;
        sh:pattern "^[0-9]{4}(/[0-9]{2})?$" ;
        sh:message "Year must have format YYYY or YYYY/YY" ;
    ] .

# Shape 5 - Person name minimum length is 1

ex:PersonNameLengthShape
    a sh:NodeShape ;
    sh:targetClass ex:Person ;
    sh:property [
        sh:path ex:name ;
        sh:minLength 1 ;
        sh:message "Name must contain at least 1 character" ;
    ] .


# Shape 6 - winner max count is 1

ex:WinnerMaxCountShape
    a sh:NodeShape ;
    sh:targetClass ex:Nomination ;
    sh:property [
        sh:path ex:winner ;
        sh:maxCount 1 ;
        sh:message "A nomination can only have 1 winner value" ;
    ] .


# Shape 7 - film must be of class Film

ex:FilmClassShape
    a sh:NodeShape ;
    sh:targetClass ex:Nomination ;
    sh:property [
        sh:path ex:film ;
        sh:class ex:Film ;
        sh:message "Film must belong to class Film" ;
    ] .

# Shape 8 - ethnicity must be one of the following: Black, White, Asian, Hispanic

ex:EthnicityShape
    a sh:NodeShape ;
    sh:targetClass ex:Person ;
    sh:property [
        sh:path ex:raceEthnicity ;
        sh:in (
            "White"
            "Black"
            "Asian"
            "Hispanic"
        ) ;
        sh:message "Ethnicity must belong to the allowed vocabulary" ;
    ] .
