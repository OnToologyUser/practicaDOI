@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix ex: <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix oscar: <http://purl.org/oscar/ontology#> .
@prefix schema: <https://schema.org/> .
@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .


# Shape 1 - Nomination must have a person

ex:NominationPersonShape
    a sh:NodeShape ;
    sh:targetClass ex:Nomination ;
    sh:property [
        sh:path ex:person ;
        sh:minCount 1 ;
        sh:message "Every nomination must reference a person." ;
    ] .

# Shape 2 - Nomination must have a film

ex:NominationFilmShape
    a sh:NodeShape ;
    sh:targetClass ex:Nomination ;
    sh:property [
        sh:path ex:film ;
        sh:minCount 1 ;
        sh:message "Every nomination must reference a film" ;
    ] .

# Shape 3 - winner must be boolean

ex:WinnerDatatypeShape
    a sh:NodeShape ;
    sh:targetClass ex:Nomination ;
    sh:property [
        sh:path ex:winner ;
        sh:datatype xsd:boolean ;
        sh:message "Winner value must be true or false" ;
    ] .

# Shape 4 - year format has to be YYYY or YYYY/YY (for seasons redacted like 1927/28)

ex:YearPatternShape
    a sh:NodeShape ;
    sh:targetClass ex:Nomination ;
    sh:property [
        sh:path ex:year ;
        sh:pattern "^[0-9]{4}(/[0-9]{2})?$" ;
        sh:message "Year must have format YYYY or YYYY/YY" ;
    ] .

# =====================================================================
# SHAPE 5: Rango de Valores - Value Range (Diapositiva 46)
# =====================================================================
# Regla: El año de la ceremonia debe ser mayor o igual a 1927.
schema:EventShape a sh:NodeShape ;
    sh:targetClass schema:Event ;
    sh:property[
        sh:path schema:startDate ; 
        sh:datatype xsd:integer ; # Usamos integer para poder comparar matemáticamente
        sh:minInclusive 1927 ;
        sh:message "Error SHAPE 1: El año de la ceremonia no puede ser anterior a 1927 (sh:minInclusive)." ;
    ] .


# Shape 6 - Person name minimum length is 1

ex:PersonNameLengthShape
    a sh:NodeShape ;
    sh:targetClass ex:Person ;
    sh:property [
        sh:path ex:name ;
        sh:minLength 1 ;
        sh:message "Name must contain at least 1 character" ;
    ] .


# Shape 7 - winner max count is 1

ex:WinnerMaxCountShape
    a sh:NodeShape ;
    sh:targetClass ex:Nomination ;
    sh:property [
        sh:path ex:winner ;
        sh:maxCount 1 ;
        sh:message "A nomination can only have 1 winner value" ;
    ] .


# Shape 8 - film must be of class Film

ex:FilmClassShape
    a sh:NodeShape ;
    sh:targetClass ex:Nomination ;
    sh:property [
        sh:path ex:film ;
        sh:class ex:Film ;
        sh:message "Film must belong to class Film" ;
    ] .


# =====================================================================
# SHAPE 9: Listas Cerradas / Enumeraciones - sh:in (Diapositiva 42)
# =====================================================================
# Regla: Acotamos la Raza, Religión y Orientación Sexual a los valores 
# estrictos extraídos de la limpieza del dataset.
schema:PersonShape a sh:NodeShape ;
    sh:targetClass schema:Person ;
    # --- Restricción para Religión ---
    sh:property[
        sh:path dbo:religion ;
        sh:in ( "Na" "Roman Catholic" "Jewish" "Atheist" "Anglican/episcopalian" "Christian" "Christian Science" "Protestant" "Deist" "Lutheran" "Presbyterian" "Baptist" "Methodist" "Born-Again Christian" "Buddhist" "Sufism" "Quaker" "Agnostic" "Congregationalist" "Disciples of Christ" "Hindu" ) ;
        sh:message "Error SHAPE 2a: La religión introducida no pertenece al vocabulario controlado del dataset." ;
    ] ;
    # --- Restricción para Raza ---
    sh:property[
        sh:path dbo:race ;
        sh:in ( "White" "Black" "Hispanic" "Asian" "Multiracial" "Middle Eastern" ) ;
        sh:message "Error SHAPE 2b: La raza o etnia introducida no es válida." ;
    ] ;
    # --- Restricción para Orientación Sexual ---
    sh:property[
        sh:path dbo:sexualOrientation ;
        sh:in ( "Bisexual" "Straight" "Gay" "Matter of Dispute" "Na" "Lesbian" ) ;
        sh:message "Error SHAPE 2c: La orientación sexual no coincide con los valores permitidos." ;
    ] .
