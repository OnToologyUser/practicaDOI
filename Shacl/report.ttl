@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix oscar: <http://purl.org/oscar/ontology#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix schema: <https://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

[] a sh:ValidationReport ;
    sh:conforms false ;
    sh:result [ a sh:ValidationResult ;
            sh:focusNode <http://example.org/data/BadCharacter> ;
            sh:resultMessage "Node data:BadCharacter is closed. It cannot have value: Literal(\"Batarang\", datatype=xsd:string)" ;
            sh:resultPath oscar:weapon ;
            sh:resultSeverity sh:Violation ;
            sh:sourceConstraintComponent sh:ClosedConstraintComponent ;
            sh:sourceShape oscar:CharacterShape ;
            sh:value "Batarang"^^xsd:string ],
        [ a sh:ValidationResult ;
            sh:focusNode <http://example.org/data/BadPerson> ;
            sh:resultMessage "Error: El nombre de la persona no puede estar vacÚo (mÚnimo 1 carÃcter)." ;
            sh:resultPath schema:name ;
            sh:resultSeverity sh:Violation ;
            sh:sourceConstraintComponent sh:MinLengthConstraintComponent ;
            sh:sourceShape [ sh:datatype xsd:string ;
                    sh:message "Error: El nombre de la persona no puede estar vacÚo (mÚnimo 1 carÃcter)." ;
                    sh:minLength 1 ;
                    sh:path schema:name ] ;
            sh:value ""^^xsd:string ],
        [ a sh:ValidationResult ;
            sh:focusNode <http://example.org/data/BadNomination> ;
            sh:resultMessage "Error: Toda nominaciµn debe referenciar a una pelÚcula de la clase schema:Movie." ;
            sh:resultPath oscar:isNominatedforMovie ;
            sh:resultSeverity sh:Violation ;
            sh:sourceConstraintComponent sh:ClassConstraintComponent ;
            sh:sourceShape [ sh:class schema:Movie ;
                    sh:message "Error: Toda nominaciµn debe referenciar a una pelÚcula de la clase schema:Movie." ;
                    sh:minCount 1 ;
                    sh:path oscar:isNominatedforMovie ] ;
            sh:value "Titanic the movie" ],
        [ a sh:ValidationResult ;
            sh:focusNode <http://example.org/data/BadNomination> ;
            sh:resultMessage "Error: El valor de isWinner debe ser un ºnico booleano (true o false)." ;
            sh:resultPath oscar:isWinner ;
            sh:resultSeverity sh:Violation ;
            sh:sourceConstraintComponent sh:DatatypeConstraintComponent ;
            sh:sourceShape [ sh:datatype xsd:boolean ;
                    sh:maxCount 1 ;
                    sh:message "Error: El valor de isWinner debe ser un ºnico booleano (true o false)." ;
                    sh:path oscar:isWinner ] ;
            sh:value "SÚ, ganµ"^^xsd:string ],
        [ a sh:ValidationResult ;
            sh:focusNode <http://example.org/data/BadEvent> ;
            sh:resultMessage "Error: El aþo de la ceremonia debe ser numÕrico y mayor o igual a 1927." ;
            sh:resultPath oscar:year ;
            sh:resultSeverity sh:Violation ;
            sh:sourceConstraintComponent sh:MinInclusiveConstraintComponent ;
            sh:sourceShape [ sh:datatype xsd:integer ;
                    sh:message "Error: El aþo de la ceremonia debe ser numÕrico y mayor o igual a 1927." ;
                    sh:minInclusive 1927 ;
                    sh:path oscar:year ] ;
            sh:value 1920 ],
        [ a sh:ValidationResult ;
            sh:focusNode <http://example.org/data/BadPerson> ;
            sh:resultMessage "Error: La religiµn no coincide con los valores permitidos del dataset." ;
            sh:resultPath dbo:religion ;
            sh:resultSeverity sh:Violation ;
            sh:sourceConstraintComponent sh:InConstraintComponent ;
            sh:sourceShape [ sh:in ( "Na" "Roman Catholic" "Jewish" "Atheist" "Anglican/episcopalian" "Christian" "Christian Science" "Protestant" "Deist" "Lutheran" "Presbyterian" "Baptist" "Methodist" "Born-Again Christian" "Buddhist" "Sufism" "Quaker" "Agnostic" "Congregationalist" "Disciples of Christ" "Hindu" ) ;
                    sh:message "Error: La religiµn no coincide con los valores permitidos del dataset." ;
                    sh:path dbo:religion ] ;
            sh:value "Jedi" ],
        [ a sh:ValidationResult ;
            sh:focusNode <http://example.org/data/BadNomination> ;
            sh:resultMessage "Error: Toda nominaciµn debe referenciar exactamente a una persona (schema:Person)." ;
            sh:resultPath schema:nominee ;
            sh:resultSeverity sh:Violation ;
            sh:sourceConstraintComponent sh:MinCountConstraintComponent ;
            sh:sourceShape [ sh:class schema:Person ;
                    sh:maxCount 1 ;
                    sh:message "Error: Toda nominaciµn debe referenciar exactamente a una persona (schema:Person)." ;
                    sh:minCount 1 ;
                    sh:path schema:nominee ] ] .

