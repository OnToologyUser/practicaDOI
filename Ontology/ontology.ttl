@prefix dc11: <http://purl.org/dc/elements/1.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dc: <http://purl.org/dc/terms/> .
@prefix ns0: <https://w3id.org/mod#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dc11:
  a owl:Ontology ;
  dc11:creator "Grupo 8" ;
  dc11:title "Oscars Ontology" ;
  owl:versionInfo "1.0.0" ;
  dc:license <https://creativecommons.org/licenses/by/4.0/> ;
  ns0:createdWith <https://chowlk.linkeddata.es/> .

dc11:creator a owl:AnnotationProperty .
dc11:title a owl:AnnotationProperty .
owl:versionInfo a owl:AnnotationProperty .
<http://purl.org/oscar/ontology#appearsInMovie>
  a owl:ObjectProperty ;
  rdfs:label "appears in movie" ;
  rdfs:domain foaf:Person ;
  rdfs:range <https://schema.org/Movie> .

<http://purl.org/oscar/ontology#happenedAt>
  a owl:ObjectProperty ;
  rdfs:label "happened at" ;
  rdfs:domain <http://purl.org/oscar/ontology#Nomination> ;
  rdfs:range <https://schema.org/Event> .

<http://purl.org/oscar/ontology#hasEthnicity>
  a owl:ObjectProperty ;
  rdfs:label "has ethnicity" ;
  rdfs:domain foaf:Person ;
  rdfs:range <http://dbpedia.org/ontology/Race> .

<http://purl.org/oscar/ontology#hasReligion>
  a owl:ObjectProperty ;
  rdfs:label "has religion" ;
  rdfs:domain foaf:Person ;
  rdfs:range <http://dbpedia.org/ontology/Religion> .

<http://purl.org/oscar/ontology#hasSexualOrientation>
  a owl:ObjectProperty ;
  rdfs:label "has sexual orientation" ;
  rdfs:domain foaf:Person ;
  rdfs:range <http://dbpedia.org/ontology/SexualOrientation> .

<http://purl.org/oscar/ontology#includesCategory>
  a owl:ObjectProperty ;
  rdfs:label "includes category" ;
  rdfs:domain <https://schema.org/Event> ;
  rdfs:range <http://purl.org/oscar/ontology#Category> .

<http://purl.org/oscar/ontology#isNominatedForMovie>
  a owl:ObjectProperty ;
  rdfs:label "is nominated for movie" ;
  rdfs:domain <http://purl.org/oscar/ontology#Nomination> ;
  rdfs:range <https://schema.org/Movie> .

<http://purl.org/oscar/ontology#isPartOfState>
  a owl:ObjectProperty ;
  rdfs:label "is part of state" ;
  rdfs:domain <http://purl.org/oscar/ontology#Place> ;
  rdfs:range <http://purl.org/oscar/ontology#State> .

<http://purl.org/oscar/ontology#plays>
  a owl:ObjectProperty ;
  rdfs:label "plays" ;
  rdfs:domain foaf:Person ;
  rdfs:range <http://purl.org/oscar/ontology#Character> .

<http://purl.org/oscar/ontology#wasBornIn>
  a owl:ObjectProperty ;
  rdfs:label "was born in" ;
  rdfs:domain foaf:Person ;
  rdfs:range <http://purl.org/oscar/ontology#Place> .

skos:broader
  a owl:ObjectProperty ;
  rdfs:label "broader" ;
  rdfs:domain <http://purl.org/oscar/ontology#Category> ;
  rdfs:range <http://purl.org/oscar/ontology#Nomination> .

<https://schema.org/nominee>
  a owl:ObjectProperty ;
  rdfs:label "nominee" ;
  rdfs:domain <http://purl.org/oscar/ontology#Nomination> ;
  rdfs:range foaf:Person .

<http://purl.org/oscar/ontology#bioURL>
  a owl:DatatypeProperty ;
  rdfs:domain foaf:Person ;
  rdfs:range xsd:anyURI .

<http://purl.org/oscar/ontology#categoryName>
  a owl:DatatypeProperty ;
  rdfs:domain <http://purl.org/oscar/ontology#Category> ;
  rdfs:range xsd:string .

<http://purl.org/oscar/ontology#dateOfBirth>
  a owl:DatatypeProperty ;
  rdfs:domain foaf:Person ;
  rdfs:range xsd:date .

<http://purl.org/oscar/ontology#eventName>
  a owl:DatatypeProperty ;
  rdfs:domain <https://schema.org/Event> ;
  rdfs:range xsd:string .

<http://purl.org/oscar/ontology#filmId>
  a owl:DatatypeProperty ;
  rdfs:domain <https://schema.org/Movie> ;
  rdfs:range xsd:integer .

<http://purl.org/oscar/ontology#isMultifilm>
  a owl:DatatypeProperty ;
  rdfs:domain <http://purl.org/oscar/ontology#Nomination> ;
  rdfs:range xsd:boolean .

<http://purl.org/oscar/ontology#isWinner>
  a owl:DatatypeProperty ;
  rdfs:domain <http://purl.org/oscar/ontology#Nomination> ;
  rdfs:range xsd:boolean .

<http://purl.org/oscar/ontology#movieName>
  a owl:DatatypeProperty ;
  rdfs:domain <https://schema.org/Movie> ;
  rdfs:range xsd:string .

<http://purl.org/oscar/ontology#name>
  a owl:DatatypeProperty ;
  rdfs:domain foaf:Person ;
  rdfs:range xsd:string .

<http://purl.org/oscar/ontology#nomId>
  a owl:DatatypeProperty ;
  rdfs:domain <http://purl.org/oscar/ontology#Nomination> ;
  rdfs:range xsd:integer .

<http://purl.org/oscar/ontology#nominationName>
  a owl:DatatypeProperty ;
  rdfs:domain <http://purl.org/oscar/ontology#Nomination> ;
  rdfs:range xsd:string .

<http://purl.org/oscar/ontology#nomineeIds>
  a owl:DatatypeProperty ;
  rdfs:domain foaf:Person ;
  rdfs:range xsd:string .

<http://purl.org/oscar/ontology#placeName>
  a owl:DatatypeProperty ;
  rdfs:domain <http://purl.org/oscar/ontology#Place> ;
  rdfs:range xsd:string .

<http://purl.org/oscar/ontology#raceName>
  a owl:DatatypeProperty ;
  rdfs:domain <http://dbpedia.org/ontology/Race> ;
  rdfs:range xsd:string .

<http://purl.org/oscar/ontology#religionName>
  a owl:DatatypeProperty ;
  rdfs:domain <http://dbpedia.org/ontology/Religion> ;
  rdfs:range xsd:string .

<http://purl.org/oscar/ontology#sexualOrientationName>
  a owl:DatatypeProperty ;
  rdfs:domain <http://dbpedia.org/ontology/SexualOrientation> ;
  rdfs:range xsd:string .

<http://purl.org/oscar/ontology#stateName>
  a owl:DatatypeProperty ;
  rdfs:domain <http://purl.org/oscar/ontology#State> ;
  rdfs:range xsd:string .

<http://purl.org/oscar/ontology#surname>
  a owl:DatatypeProperty ;
  rdfs:domain foaf:Person ;
  rdfs:range xsd:string .

<http://purl.org/oscar/ontology#year>
  a owl:DatatypeProperty ;
  rdfs:domain <https://schema.org/Event> ;
  rdfs:range xsd:integer .

<http://dbpedia.org/ontology/Race>
  a owl:Class ;
  rdfs:label "Race" .

<http://dbpedia.org/ontology/Religion>
  a owl:Class ;
  rdfs:label "Religion" .

<http://dbpedia.org/ontology/SexualOrientation>
  a owl:Class ;
  rdfs:label "Sexual Orientation" .

<http://purl.org/oscar/ontology#State>
  a owl:Class ;
  rdfs:label "State" .

<http://purl.org/oscar/ontology#Category>
  a owl:Class ;
  rdfs:label "Category" .

<http://purl.org/oscar/ontology#Place>
  a owl:Class ;
  rdfs:label "Place" .

<https://schema.org/Event>
  a owl:Class ;
  rdfs:label "Event" .

<https://schema.org/Movie>
  a owl:Class ;
  rdfs:label "Movie" .

<http://purl.org/oscar/ontology#Nomination>
  a owl:Class ;
  rdfs:label "Nomination" .

foaf:Person
  a owl:Class ;
  rdfs:label "Person" .

<http://purl.org/oscar/ontology#Character>
  a owl:Class ;
  rdfs:label "Character" .

[]
  a owl:AllDisjointClasses ;
  owl:members (
   foaf:Person
   <https://schema.org/Movie>
   <https://schema.org/Event>
   <http://purl.org/oscar/ontology#Nomination>
   <http://purl.org/oscar/ontology#Category>
   <http://purl.org/oscar/ontology#Character>
 ) .
