@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix mod: <https://w3id.org/mod#> .
@prefix oscar: <http://purl.org/oscar/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

dc: a owl:Ontology ;
    dc:creator "Grupo 8" ;
    dc:title "Oscars Ontology" ;
    owl:versionInfo "1.0.0" ;
    mod:createdWith <https://chowlk.linkeddata.es/> .

dc:creator a owl:AnnotationProperty .

dc:title a owl:AnnotationProperty .

oscar:appearsInMovie a owl:ObjectProperty ;
    rdfs:label "appears in movie" ;
    rdfs:domain schema:Movie ;
    rdfs:range foaf:Person .

oscar:bioURL a owl:DatatypeProperty ;
    rdfs:label "bio u r l" ;
    rdfs:domain foaf:Person .

oscar:categoryName a owl:DatatypeProperty ;
    rdfs:label "category name" ;
    rdfs:domain oscar:Category .

oscar:dateOfBirth a owl:DatatypeProperty ;
    rdfs:label "date of birth" ;
    rdfs:domain foaf:Person .

oscar:eventName a owl:DatatypeProperty ;
    rdfs:label "event name" ;
    rdfs:domain schema:Event .

oscar:filmId a owl:DatatypeProperty ;
    rdfs:label "film id" ;
    rdfs:domain schema:Movie .

oscar:happenedAt a owl:ObjectProperty ;
    rdfs:label "happened at" ;
    rdfs:domain oscar:Nomination ;
    rdfs:range schema:Event .

oscar:hasEthnicity a owl:ObjectProperty ;
    rdfs:label "has ethnicity" ;
    rdfs:domain foaf:Person ;
    rdfs:range dbo:Race .

oscar:hasReligion a owl:ObjectProperty ;
    rdfs:label "has religion" ;
    rdfs:domain foaf:Person ;
    rdfs:range dbo:Religion .

oscar:hasSexualOrientation a owl:ObjectProperty ;
    rdfs:label "has sexual orientation" ;
    rdfs:domain foaf:Person ;
    rdfs:range dbo:SexualOrientation .

oscar:includesCategory a owl:ObjectProperty ;
    rdfs:label "includes category" ;
    rdfs:domain schema:Event ;
    rdfs:range oscar:Category .

oscar:isMultifilm a owl:DatatypeProperty ;
    rdfs:label "is multifilm" ;
    rdfs:domain oscar:Nomination .

oscar:isNominatedForMovie a owl:ObjectProperty ;
    rdfs:label "is nominated for movie" ;
    rdfs:domain oscar:Nomination ;
    rdfs:range schema:Movie .

oscar:isPartOfState a owl:ObjectProperty ;
    rdfs:label "is part of state" ;
    rdfs:domain oscar:Place ;
    rdfs:range oscar:State .

oscar:isWinner a owl:DatatypeProperty ;
    rdfs:label "is winner" ;
    rdfs:domain oscar:Nomination .

oscar:movieName a owl:DatatypeProperty ;
    rdfs:label "movie name" ;
    rdfs:domain schema:Movie .

oscar:name a owl:DatatypeProperty ;
    rdfs:label "name" ;
    rdfs:domain foaf:Person .

oscar:nomId a owl:DatatypeProperty ;
    rdfs:label "nom id" ;
    rdfs:domain oscar:Nomination .

oscar:nominationName a owl:DatatypeProperty ;
    rdfs:label "nomination name" ;
    rdfs:domain oscar:Nomination .

oscar:nomineeIds a owl:DatatypeProperty ;
    rdfs:label "nominee ids" ;
    rdfs:domain foaf:Person .

oscar:placeName a owl:DatatypeProperty ;
    rdfs:label "place name" ;
    rdfs:domain oscar:Place .

oscar:plays a owl:ObjectProperty ;
    rdfs:label "plays" ;
    rdfs:domain foaf:Person ;
    rdfs:range oscar:Character .

oscar:raceName a owl:DatatypeProperty ;
    rdfs:label "race name" ;
    rdfs:domain dbo:Race .

oscar:religionName a owl:DatatypeProperty ;
    rdfs:label "religion name" ;
    rdfs:domain dbo:Religion .

oscar:sexualOrientationName a owl:DatatypeProperty ;
    rdfs:label "sexual orientation name" ;
    rdfs:domain dbo:SexualOrientation .

oscar:stateName a owl:DatatypeProperty ;
    rdfs:label "state name" ;
    rdfs:domain oscar:State .

oscar:surname a owl:DatatypeProperty ;
    rdfs:label "surname" ;
    rdfs:domain foaf:Person .

oscar:wasBornIn a owl:ObjectProperty ;
    rdfs:label "was born in" ;
    rdfs:domain foaf:Person ;
    rdfs:range oscar:Place .

oscar:year a owl:DatatypeProperty ;
    rdfs:label "year" ;
    rdfs:domain schema:Event .

owl:versionInfo a owl:AnnotationProperty .

skos:broader a owl:ObjectProperty ;
    rdfs:label "broader" ;
    rdfs:domain oscar:Category ;
    rdfs:range oscar:Nomination .

schema:nominee a owl:ObjectProperty ;
    rdfs:label "nominee" ;
    rdfs:domain oscar:Nomination ;
    rdfs:range foaf:Person .

oscar:Character a owl:Class ;
    rdfs:label "Character" .

dbo:Race a owl:Class ;
    rdfs:label "Race" .

dbo:Religion a owl:Class ;
    rdfs:label "Religion" .

dbo:SexualOrientation a owl:Class ;
    rdfs:label "Sexual Orientation" .

oscar:State a owl:Class ;
    rdfs:label "State" .

oscar:Category a owl:Class ;
    rdfs:label "Category" .

oscar:Place a owl:Class ;
    rdfs:label "Place" .

schema:Event a owl:Class ;
    rdfs:label "Event" .

schema:Movie a owl:Class ;
    rdfs:label "Movie" .

oscar:Nomination a owl:Class ;
    rdfs:label "Nomination" .

foaf:Person a owl:Class ;
    rdfs:label "Person" .

